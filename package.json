{
  "name": "cloud-logging-mcp",
  "version": "1.0.0",
  "description": "Google Cloud Logging MCP Server - A Model Context Protocol server for accessing Google Cloud logs",
  "main": "dist/index.js",
  "module": "./src/index.ts",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "smithery.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "smithery dev",
    "dev:stdio": "tsx watch src/main.ts",
    "build": "npm run build:http",
    "build:stdio": "tsc --project tsconfig.build.json",
    "build:http": "smithery build",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "start": "npm run start:http",
    "start:http": "node .smithery/index.cjs",
    "start:stdio": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "RUN_E2E=1 vitest run src/e2e.test.ts",
    "test:all": "RUN_E2E=1 vitest run",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "check": "concurrently -c auto -g \"npm run typecheck\" \"npm run lint\" \"npm run test\" \"npm run knip\"",
    "check:all": "concurrently -c auto -g \"npm run typecheck\" \"npm run lint\" \"npm run test:all\" \"npm run knip\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build:stdio",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-cloud",
    "cloud-logging",
    "ai",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/monitoring": "^5.3.1",
    "@google-cloud/resource-manager": "^6.2.1",
    "@grpc/grpc-js": "^1.14.3",
    "@modelcontextprotocol/sdk": "^1.13.1",
    "google-auth-library": "^10.6.2",
    "google-proto-files": "^5.0.1",
    "neverthrow": "^8.2.0",
    "protobufjs": "^8.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@smithery/cli": "^4.11.0",
    "@smithery/sdk": "^4.3.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@typescript/native-preview": "^7.0.0-dev.20250625.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-functional": "^9.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "knip": "^6.8.0",
    "prettier": "^3.6.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
